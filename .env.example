APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Tenant public sites: prod host {nick}.TENANT_WEBSITE_DOMAIN; dev host {nick}-st.debian when APP_URL ends with .debian
# TENANT_WEBSITE_DOMAIN=simple-travel.net
# TENANT_WEBSITE_DEV_SUFFIX=-st.debian

# Tenant public theme static files (default public/site/assets). Run: php artisan site:publish-assets
# TENANT_SITE_ASSETS_PATH=site/assets

# Spatie Permission: reserved account id for platform-wide roles (team). Default 1.
PLATFORM_ACCOUNT_ID=1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Addons DB (lmp_* tables). Omit to fallback to main DB credentials.
# DB_ADDONS_HOST=127.0.0.1
# DB_ADDONS_PORT=3306
# DB_ADDONS_DATABASE=addons
# DB_ADDONS_USERNAME=root
# DB_ADDONS_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Service images (Spatie): local storage under storage/app/public/service-media. Set to s3 for AWS (same AWS_* as below).
# SERVICE_MEDIA_DISK_DRIVER=local
QUEUE_CONNECTION=database
DB_QUEUE_TABLE=sys_jobs
DB_JOB_BATCHES_TABLE=sys_job_batches
DB_FAILED_JOBS_TABLE=sys_failed_jobs

CACHE_STORE=database
CACHE_PREFIX=
DB_CACHE_TABLE=sys_cache
DB_CACHE_LOCK_TABLE=sys_cache_locks
SESSION_TABLE=sys_sessions
AUTH_PASSWORD_RESET_TOKEN_TABLE=sys_password_reset_tokens
# Keep default unless you run the dedicated manual migration-repo rename procedure.
DB_MIGRATIONS_TABLE=migrations

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Mapbox: public token (pk.*) for maps on contact page. Optional; without it, OpenStreetMap is used.
# MAPBOX_PUBLIC_TOKEN=

# Exchange rate API (used by currency:fetch-rates). api_key is sent as query param.
# EXCHANGERATE_URL=https://api.currencylayer.com/live
# EXCHANGERATE_API_KEY=

# Translation API endpoint for wizard description auto-translation.
# Default points to a free public service (modest usage).
# TRANSLATION_API_URL=https://api.mymemory.translated.net/get

# Social login (OAuth)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

ACTIVITY_LOGGER_TABLE_NAME=sys_activity_log
MEDIA_LIBRARY_TABLE_NAME=sys_media

VITE_APP_NAME="${APP_NAME}"
